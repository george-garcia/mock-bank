# Mock Bank - Environment Template
NODE_ENV=development

# Database
DATABASE_URL=postgres://mockbank:mockbank_dev_password@localhost:5432/mockbank

# JWT / sessions (generate a strong secret for production)
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=15       # short-lived access token (httpOnly cookie)
REFRESH_TOKEN_DAYS=7         # refresh token lifetime (httpOnly cookie, rotated)
COOKIE_SAMESITE=lax         # lax | strict | none (none requires HTTPS)

# Lithic (leave as mock-key for sandbox mode)
LITHIC_API_KEY=mock-key
LITHIC_BASE_URL=https://sandbox.lithic.com/v1
# HMAC secret for verifying inbound Lithic webhooks. Leave blank in mock/dev to skip
# verification; MUST be set in production.
LITHIC_WEBHOOK_SECRET=

# Frontend
FRONTEND_URL=http://localhost:5173

# API (bank backend — customers)
API_PORT=3000

# Admin API (back-office backend — staff; separate application, shares this database)
ADMIN_API_PORT=4001
ADMIN_FRONTEND_URL=http://localhost:5174
# Separate signing secret for staff sessions (falls back to JWT_SECRET if unset).
ADMIN_JWT_SECRET=change-me-in-production-admin

# Deposits — ACH clearing delay for non-instant deposits (seconds; real ACH is 1-3 days)
PENDING_CLEAR_SECONDS=5

# Two-Factor Authentication
TOTP_ISSUER=Mock Bank          # label shown in authenticator apps
OTP_LENGTH=6                   # length of emailed one-time codes
OTP_EXP_MINUTES=10            # how long emailed codes stay valid
TWO_FA_CHALLENGE_EXP=10m      # how long a login 2FA challenge stays valid

# Email / SMTP (for email OTP delivery)
# Leave SMTP_HOST blank to log codes to the API console instead of sending email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Mock Bank <noreply@mockbank.local>
