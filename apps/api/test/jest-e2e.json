{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@mock-bank/database$": "<rootDir>/../test/mocks/database.mock.ts",
    "^@mock-bank/types$": "<rootDir>/../../packages/types/src/index.ts"
  }
}
